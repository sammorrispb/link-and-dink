# Supabase — link-and-dink project
# The publishable key is safe to expose; public writes are gated by an
# INSERT-only RLS policy on `subscribers`.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Service-role secret — SERVER ONLY, bypasses RLS. Used by the newsletter
# platform to read the subscriber list and write issues/sends/events.
# Never expose to the client. Get from Supabase dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# Newsletter
SITE_URL=https://www.linkanddink.com
# Which email provider sends mail: noop (logs only) | resend
EMAIL_PROVIDER=noop
EMAIL_FROM=MoCoNews@linkanddink.com
# Physical postal address shown in every email footer — required by CAN-SPAM.
NEWSLETTER_MAILING_ADDRESS=
# Only needed when EMAIL_PROVIDER=resend
RESEND_API_KEY=
# Svix signing secret for the Resend bounce/complaint webhook (whsec_...)
RESEND_WEBHOOK_SECRET=

# Coach Up — where new /coach-up/apply submissions are emailed for screening.
COACH_UP_NOTIFY_EMAIL=sam@linkanddink.com

# Admin — single-operator gate for /admin
ADMIN_PASSWORD=
# Secret for signing the admin session cookie (e.g. `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=

# Cron — bearer token the Vercel cron presents to /api/cron/drain
CRON_SECRET=

# Link signing — HMAC secret for signed email links, e.g. confirm + tracking
# (e.g. `openssl rand -hex 32`)
LINK_SIGNING_SECRET=
