# ---------------------------------------------------------------------------
# Pot Night — environment variables
# Copy to .env.local for local dev. Set the same keys in Vercel project settings.
# ---------------------------------------------------------------------------

# Supabase ---------------------------------------------------------------------
# From `supabase status` (local) or the Supabase dashboard (hosted project).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the client. Used by seed/admin scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site -------------------------------------------------------------------------
# Used for magic-link redirects and OG image absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (Phase 1: STUBBED — no real charges) ---------------------------------
# Feature flag. Leave false for Phase 1. When true (Phase 2), RSVP routes
# through Stripe Checkout instead of recording payment_status='intent'.
STRIPE_LIVE=false
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
